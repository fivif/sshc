<script>
let auth_mode = 'key';
let key_content = null;
let key_filename = '';

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function setAuth(m) {
  auth_mode = m;
  document.getElementById('bt_key').className = m==='key'?'active':'';
  document.getElementById('bt_pw').className = m==='password'?'active':'';
  document.getElementById('key_group').style.display = m==='key'?'':'none';
  document.getElementById('f_password').style.display = m==='password'?'':'none';
}

// ── Drop zone ──────────────────────────────────────────────────────
(function() {
  const drop = document.getElementById('key_drop');
  const file = document.getElementById('key_file_input');
  const name = drop.querySelector('.drop-name');
  const text = drop.querySelector('.drop-text');

  drop.addEventListener('click', function() { file.click(); });

  drop.addEventListener('dragover', function(e) { e.preventDefault(); drop.classList.add('drag'); });
  drop.addEventListener('dragleave', function() { drop.classList.remove('drag'); });
  drop.addEventListener('drop', function(e) {
    e.preventDefault();
    drop.classList.remove('drag');
    handleFile(e.dataTransfer.files[0]);
  });

  file.addEventListener('change', function() {
    if (this.files.length) handleFile(this.files[0]);
  });

  function handleFile(f) {
    if (!f) return;
    var reader = new FileReader();
    reader.onload = function(e) {
      key_content = e.target.result.split(',')[1] || e.target.result;
      key_filename = f.name;
      drop.classList.add('has');
      name.textContent = f.name;
      text.textContent = '已选择 — 点击可重新选择';
    };
    reader.readAsDataURL(f);
  }
})();

function msg(text, type) {
  const el = document.getElementById('msg');
  el.textContent = text;
  el.className = 'msg ' + type;
  setTimeout(function() { el.className = 'msg'; }, 3000);
}

async function api(method, path, body) {
  const r = await fetch(path, {method, headers:{'Content-Type':'application/json'}, body:body?JSON.stringify(body):undefined});
  return r.json();
}

async function addProfile() {
  const name = document.getElementById('f_name').value.trim();
  const host = document.getElementById('f_host').value.trim();
  const user = document.getElementById('f_user').value.trim();
  const port = parseInt(document.getElementById('f_port').value) || 22;
  const password = document.getElementById('f_password').value.trim();

  if (!name || !host) return msg('名称和主机不能为空', 'err');

  var payload = {name:name, host:host, user:user, port:port};
  if (auth_mode === 'key') {
    if (key_content) {
      payload.key_content = key_content;
      payload.key_filename = key_filename;
    }
  } else {
    if (!password) return msg('请输入密码', 'err');
    payload.password = password;
  }

  var r = await api('POST', '/api/profiles', payload);
  if (r.ok) {
    msg('已添加: ' + name, 'ok');
    document.getElementById('f_name').value = '';
    document.getElementById('f_host').value = '';
    document.getElementById('f_password').value = '';
    key_content = null; key_filename = '';
    var drop = document.getElementById('key_drop');
    drop.classList.remove('has');
    drop.querySelector('.drop-name').textContent = '';
    drop.querySelector('.drop-text').textContent = '拖入密钥文件 或 点击选择';
    document.getElementById('key_file_input').value = '';
    refresh();
  } else {
    msg(r.error || '添加失败', 'err');
  }
}

async function deleteProfile(name) {
  if (!confirm('删除服务器 ' + name + '？')) return;
  var r = await api('DELETE', '/api/profiles/' + encodeURIComponent(name));
  if (r.ok) { msg('已删除: ' + name, 'ok'); refresh(); }
  else msg(r.error || '删除失败', 'err');
}

async function setDefault(name) {
  await api('PUT', '/api/profiles/' + encodeURIComponent(name), {default: true});
  refresh();
}

async function testProfile(name) {
  var row = document.getElementById('row-' + CSS.escape(name));
  var dot = row ? row.querySelector('.status') : null;
  var btn = document.querySelector('[data-action="test"][data-name="' + CSS.escape(name) + '"]');
  if (dot) dot.className = 'status checking';
  if (btn) { btn.textContent = '...'; btn.disabled = true; }

  var r = await api('POST', '/api/test/' + encodeURIComponent(name));

  if (dot) dot.className = 'status ' + (r.alive ? 'alive' : 'dead');
  if (btn) {
    btn.textContent = r.alive ? '●' : '○';
    btn.style.color = r.alive ? 'var(--green)' : 'var(--red)';
    btn.disabled = false;
  }
}

function updateRowStatus(name, alive) {
  var row = document.getElementById('row-' + CSS.escape(name));
  if (!row) return;
  var dot = row.querySelector('.status');
  if (dot) dot.className = 'status ' + (alive ? 'alive' : 'dead');
  var btn = row.querySelector('[data-action="test"]');
  if (btn) {
    btn.textContent = alive ? '●' : '○';
    btn.style.color = alive ? 'var(--green)' : 'var(--red)';
    btn.disabled = false;
  }
}

async function checkAll() {
  var rows = document.querySelectorAll('#list tr[data-name]');
  var tasks = [];
  rows.forEach(function(row) {
    var name = row.dataset.name;
    tasks.push(
      api('POST', '/api/test/' + encodeURIComponent(name))
        .then(function(r) { updateRowStatus(name, r.alive); })
        .catch(function() { updateRowStatus(name, false); })
    );
  });
  await Promise.allSettled(tasks);
}

document.addEventListener('click', function(e) {
  var btn = e.target.closest('button[data-action]');
  if (!btn) return;
  var name = btn.dataset.name;
  var action = btn.dataset.action;
  if (action === 'test') testProfile(name);
  else if (action === 'delete') deleteProfile(name);
  else if (action === 'default') setDefault(name);
  else if (action === 'proxy') openProxyModal(name, btn.dataset.proxy);
});

// ── Proxy modal ─────────────────────────────────────────────────────
let proxy_edit_name = '';

function parseProxyType(raw) {
  if (!raw) return '';
  if (/[-\s]5[-\s]/.test(raw) || /socks5/i.test(raw)) return 'socks5';
  if (/[-\s]4[-\s]/.test(raw) || /socks4/i.test(raw)) return 'socks4';
  if (/connect/i.test(raw) || /http/i.test(raw) || /https/i.test(raw)) return 'http';
  return 'raw';
}

function parseProxyHostPort(raw) {
  var m = raw.match(/-x\s+(\S+)/);
  if (!m) return ['', ''];
  var parts = m[1].split(':');
  return [parts[0] || '', parts[1] || ''];
}

function buildProxyCommand(type, host, port) {
  if (type === 'http')  return 'nc -X connect -x ' + host + ':' + (port||'1080') + ' %h %p';
  if (type === 'socks5') return 'nc -X 5 -x ' + host + ':' + (port||'1080') + ' %h %p';
  if (type === 'socks4') return 'nc -X 4 -x ' + host + ':' + (port||'1080') + ' %h %p';
  return '';
}

function openProxyModal(name, raw) {
  proxy_edit_name = name;
  document.getElementById('proxy_modal_name').textContent = name;
  var type = parseProxyType(raw);
  document.getElementById('proxy_type').value = type;
  var hp = parseProxyHostPort(raw);
  document.getElementById('proxy_host').value = hp[0];
  document.getElementById('proxy_port').value = hp[1];
  document.getElementById('proxy_raw').value = type === 'raw' ? raw : '';
  document.getElementById('proxy_clear_btn').style.display = raw ? '' : 'none';
  updateProxyFields();
  document.getElementById('proxy_modal').classList.add('open');
}

function closeProxyModal() {
  document.getElementById('proxy_modal').classList.remove('open');
}

function updateProxyFields() {
  var type = document.getElementById('proxy_type').value;
  var showFields = type === 'http' || type === 'socks5' || type === 'socks4';
  var showRaw = type === 'raw';
  document.getElementById('proxy_fields').style.display = showFields ? '' : 'none';
  document.getElementById('proxy_raw_field').style.display = showRaw ? '' : 'none';
  if (showFields) {
    var host = document.getElementById('proxy_host').value.trim();
    var port = document.getElementById('proxy_port').value.trim();
    if (host) {
      document.getElementById('proxy_preview').textContent = '预览: ' + buildProxyCommand(type, host, port);
    } else {
      document.getElementById('proxy_preview').textContent = '';
    }
  } else if (showRaw) {
    document.getElementById('proxy_preview').textContent = '';
  } else {
    document.getElementById('proxy_preview').textContent = '';
  }
}

async function saveProxy() {
  var type = document.getElementById('proxy_type').value;
  var proxy_str = '';
  if (type === 'http' || type === 'socks5' || type === 'socks4') {
    var host = document.getElementById('proxy_host').value.trim();
    var port = document.getElementById('proxy_port').value.trim();
    if (!host) return msg('请输入代理主机', 'err');
    proxy_str = buildProxyCommand(type, host, port);
  } else if (type === 'raw') {
    proxy_str = document.getElementById('proxy_raw').value.trim();
    if (!proxy_str) return msg('请输入 ProxyCommand', 'err');
  }
  var r = await api('PUT', '/api/profiles/' + encodeURIComponent(proxy_edit_name), {proxy: proxy_str || null});
  if (r.ok) {
    msg('代理设置已保存: ' + proxy_edit_name, 'ok');
    closeProxyModal();
    refresh();
  } else {
    msg(r.error || '保存失败', 'err');
  }
}

async function clearProxy() {
  var r = await api('PUT', '/api/profiles/' + encodeURIComponent(proxy_edit_name), {proxy: null});
  if (r.ok) {
    msg('代理已清除: ' + proxy_edit_name, 'ok');
    closeProxyModal();
    refresh();
  } else {
    msg(r.error || '清除失败', 'err');
  }
}

document.getElementById('proxy_type').addEventListener('change', updateProxyFields);
document.getElementById('proxy_host').addEventListener('input', updateProxyFields);
document.getElementById('proxy_port').addEventListener('input', updateProxyFields);

async function refresh() {
  var r = await api('GET', '/api/profiles');
  var list = document.getElementById('list');
  if (!r.profiles || Object.keys(r.profiles).length === 0) {
    list.innerHTML = '<div class="empty">还没有服务器，添加第一个吧</div>';
    return;
  }

  var html = '<table><tr><th>状态</th><th>名称</th><th>主机</th><th>用户</th><th>端口</th><th></th></tr>';
  for (var n in r.profiles) {
    var p = r.profiles[n];
    var isDef = n === r.default;
    html += '<tr id="row-' + escHtml(n) + '" data-name="' + escHtml(n) + '">' +
      '<td><span class="status checking"></span></td>' +
      '<td>' + escHtml(n) + (isDef ? '<span class="badge def">默认</span>' : '') + '</td>' +
      '<td>' + escHtml(p.host) + '</td>' +
      '<td>' + escHtml(p.user||'root') + '</td>' +
      '<td>' + escHtml(String(p.port||22)) + '</td>' +
      '<td>' +
        '<button class="btn-test" data-action="test" data-name="' + escHtml(n) + '">测试</button>' +
        '<button class="btn-proxy' + (p.proxy ? ' has-proxy' : '') + '" data-action="proxy" data-name="' + escHtml(n) + '" data-proxy="' + escHtml(p.proxy||'') + '" style="margin-left:4px">代理</button>' +
        (!isDef ? '<button class="btn btn-del" data-action="default" data-name="' + escHtml(n) + '" style="margin-left:4px;font-size:11px;padding:3px 8px;border-color:var(--border);color:var(--muted)">默认</button>' : '') +
        '<button class="btn btn-del" data-action="delete" data-name="' + escHtml(n) + '" style="margin-left:4px">删除</button>' +
      '</td></tr>';
  }
  html += '</table>';
  list.innerHTML = html;

  checkAll();
}

refresh();
</script>
</body>
</html>"""

def load_profiles():
    os.makedirs(APP_DIR, exist_ok=True)
    if not os.path.exists(PROFILES_FILE):
        with open(PROFILES_FILE, "w") as f:
            json.dump({"default": "", "servers": {}}, f, indent=2)
    with open(PROFILES_FILE) as f:
        return json.load(f)

def save_profiles(cfg):
    tmp = PROFILES_FILE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(cfg, f, indent=2, ensure_ascii=False)
    os.replace(tmp, PROFILES_FILE)
    os.chmod(PROFILES_FILE, 0o600)

def save_key_content(name, content_b64, filename):
    """Save uploaded key file to ~/.sshc/keys/<name>/<filename>, return path."""
    safe_name = os.path.basename(filename)
    key_dir = os.path.join(KEYS_DIR, name)
    os.makedirs(key_dir, exist_ok=True)
    os.chmod(key_dir, 0o700)
    key_path = os.path.join(key_dir, safe_name)
    try:
        raw = base64.b64decode(content_b64)
    except Exception:
        return None
    with open(key_path, "wb") as f:
        f.write(raw)
    os.chmod(key_path, 0o600)
    return key_path

def check_alive(name, cfg):
    """check server alive through sshc daemon (cross-platform IPC)"""
    if name not in cfg.get("servers", {}):
        return False

    IS_WIN = platform.system() == "Windows"

    if IS_WIN:
        port_file = os.path.join(APP_DIR, "daemon.port")
        if not os.path.exists(port_file):
            return False
        try:
            port = int(open(port_file).read().strip())
            s = socket.create_connection(("127.0.0.1", port), timeout=5)
        except Exception:
            return False
    else:
        daemon_sock = os.path.join(APP_DIR, "daemon.sock")
        if not os.path.exists(daemon_sock):
            return False
        try:
            s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
            s.settimeout(5)
            s.connect(daemon_sock)
        except Exception:
            return False

    try:
        req = json.dumps({"action": "health", "profile": name})
        s.sendall((req + "\n").encode())
        data = b""
        while True:
            chunk = s.recv(65536)
            if not chunk: break
            data += chunk
            if b"\n" in data: break
        s.close()
        resp = json.loads(data.decode().strip())
        return resp.get("alive", False)
    except Exception:
        return False

class Handler(BaseHTTPRequestHandler):
    def log_message(self, *a): pass

    def _path_name(self, prefix="/api/profiles/"):
        u = urlparse(self.path)
        return unquote(u.path.split("/")[-1])

    def _json(self, data, status=200):
        body = json.dumps(data, ensure_ascii=False, indent=2)
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Cache-Control", "no-cache, no-store, must-revalidate")
        self.send_header("Content-Length", str(len(body.encode())))
        self.end_headers()
        self.wfile.write(body.encode())

    def _read_body(self):
        length = int(self.headers.get("Content-Length", 0))
        if length == 0: return {}
        raw = self.rfile.read(length).decode()
        return json.loads(raw) if raw else {}

    def do_GET(self):
        u = urlparse(self.path)
        if u.path == "/" or u.path == "/index.html":
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Cache-Control", "no-cache, no-store, must-revalidate")
            self.send_header("Content-Length", str(len(HTML.encode())))
            self.end_headers()
            self.wfile.write(HTML.encode())
        elif u.path == "/api/profiles":
            cfg = load_profiles()
            result = {"default": cfg.get("default", ""), "profiles": {}}
            for name, s in cfg.get("servers", {}).items():
                result["profiles"][name] = {
                    "host": s["host"], "user": s.get("user", "root"),
                    "port": s.get("port", 22), "alive": None,
                    "has_key": "key" in s, "has_password": "password" in s,
                    "proxy": s.get("proxy", ""),
                }
            self._json(result)
        else:
            self._json({"error": "not found"}, 404)

    def do_POST(self):
        u = urlparse(self.path)
        body = self._read_body()

        if u.path == "/api/profiles":
            name = body.get("name", "").strip()
            if not name:
                return self._json({"ok": False, "error": "name required"}, 400)
            cfg = load_profiles()
            if "servers" not in cfg: cfg["servers"] = {}
            srv = {"host": body["host"], "user": body.get("user", "root"),
                   "port": int(body.get("port", 22))}

            key_content = body.get("key_content")
            if key_content:
                key_filename = body.get("key_filename", "id_rsa")
                key_path = save_key_content(name, key_content, key_filename)
                if key_path:
                    srv["key"] = key_path
                else:
                    return self._json({"ok": False, "error": "failed to decode key file"}, 400)
            elif body.get("key"):
                srv["key"] = body["key"]

            if body.get("password"):
                srv["password"] = body["password"]
            if body.get("proxy"):
                srv["proxy"] = body["proxy"]

            cfg["servers"][name] = srv
            if not cfg.get("default"):
                cfg["default"] = name
            save_profiles(cfg)
            self._json({"ok": True, "name": name, "msg": "profile added"})

        elif u.path.startswith("/api/test/"):
            name = self._path_name("/api/test/")
            cfg = load_profiles()
            alive = check_alive(name, cfg)
            self._json({"ok": True, "name": name, "alive": alive})

        else:
            self._json({"error": "not found"}, 404)

    def do_DELETE(self):
        u = urlparse(self.path)
        if u.path.startswith("/api/profiles/"):
            name = self._path_name()
            cfg = load_profiles()
            if name not in cfg.get("servers", {}):
                return self._json({"ok": False, "error": f"profile not found: {name}"}, 404)
            del cfg["servers"][name]
            if cfg.get("default") == name:
                cfg["default"] = next(iter(cfg.get("servers", {})), "")
            save_profiles(cfg)
            self._json({"ok": True, "name": name, "msg": "profile removed"})
        else:
            self._json({"error": "not found"}, 404)

    def do_PUT(self):
        u = urlparse(self.path)
        body = self._read_body()
        if u.path.startswith("/api/profiles/"):
            name = self._path_name()
            cfg = load_profiles()
            if name not in cfg.get("servers", {}):
                return self._json({"ok": False, "error": f"profile not found: {name}"}, 404)
            updated = False
            if body.get("default"):
                cfg["default"] = name
                updated = True
            if "proxy" in body:
                if body["proxy"] is None or body["proxy"] == "":
                    cfg["servers"][name].pop("proxy", None)
                else:
                    cfg["servers"][name]["proxy"] = body["proxy"]
                updated = True
            if updated:
                save_profiles(cfg)
            self._json({"ok": True, "name": name, "msg": "updated"})
        else:
            self._json({"error": "not found"}, 404)

    def do_OPTIONS(self):
        self.send_response(204)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.end_headers()

def main():
    port = int(sys.argv[2]) if len(sys.argv) > 2 and sys.argv[1] == "-p" else 17375
    server = HTTPServer((BIND, port), Handler)
    print(f"sshc-web: http://{BIND}:{port}")
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\nshutdown")
        server.server_close()

if __name__ == "__main__":
    main()
