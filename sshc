#!/bin/bash
# sshc — SSH multiplexing CLI (cross-platform shell client)
# Daemon: C (cross-platform) | Client: pure bash + nc

set -e
APP_DIR="${HOME}/.sshc"
PROFILES_FILE="${APP_DIR}/profiles.json"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd -P)"

# ── platform detection ─────────────────────────────────────────────
IS_WIN=0
case "$(uname -s 2>/dev/null || echo Windows)" in
    CYGWIN*|MINGW*|MSYS*|Windows) IS_WIN=1 ;;
esac

if [ "$IS_WIN" -eq 1 ]; then
    DAEMON_NAME="sshc-daemon.exe"
    DAEMON_SOCK=""  # unused on Windows — use TCP port file
else
    DAEMON_NAME="sshc-daemon"
    DAEMON_SOCK="${APP_DIR}/daemon.sock"
fi

# ── auto-discover or compile daemon binary ──────────────────────────
_find_or_build() {
    local name="$1"
    local src="${2:-}"
    for dir in "$SCRIPT_DIR" \
               "$HOME/.claude/skills/sshc" \
               "$HOME/.agents/skills/sshc"; do
        if [ -x "$dir/$name" ] || [ -f "$dir/$name" ]; then
            echo "$dir/$name"; return 0
        fi
    done
    if [ -n "$src" ] && [ -f "$SCRIPT_DIR/$src" ]; then
        echo "Building $name from source..." >&2
        local libs=""
        [ "$IS_WIN" -eq 1 ] && libs="-lws2_32"
        cc -O2 -o "$SCRIPT_DIR/$name" "$SCRIPT_DIR/$src" $libs && \
            { echo "$SCRIPT_DIR/$name"; return 0; }
    fi
    echo "$SCRIPT_DIR/$name"
}
DAEMON_BIN="$(_find_or_build $DAEMON_NAME sshc-daemon.c)"
WEB_BIN="$(_find_or_build sshc-web)"

# ── daemon alive check ──────────────────────────────────────────────
_daemon_alive() {
    if [ "$IS_WIN" -eq 1 ]; then
        local pf="${APP_DIR}/daemon.port"
        [ -f "$pf" ] || return 1
        local port
        port=$(cat "$pf" 2>/dev/null)
        [ -n "$port" ] && nc -z 127.0.0.1 "$port" 2>/dev/null
    else
        [ -S "$DAEMON_SOCK" ]
    fi
}

# ── IPC send ────────────────────────────────────────────────────────
send() {
    if ! _daemon_alive; then
        echo '{"ok":false,"error":"daemon not running. Start with: sshc daemon"}' >&2
        return 1
    fi
    if [ "$IS_WIN" -eq 1 ]; then
        local port
        port=$(cat "${APP_DIR}/daemon.port" 2>/dev/null)
        printf '%s\n' "$1" | nc -w 5 127.0.0.1 "$port" 2>/dev/null
    else
        printf '%s\n' "$1" | nc -U "$DAEMON_SOCK" 2>/dev/null
    fi
}

# ── commands ────────────────────────────────────────────────────────
cmd_daemon() {
    if _daemon_alive; then
        echo "sshc daemon already running"
        return 0
    fi

    echo "Starting sshc daemon..."
    "$DAEMON_BIN" &
    sleep 1
    if _daemon_alive; then
        echo "sshc daemon ready"
    else
        echo "ERROR: daemon failed to start" >&2
        return 1
    fi
}

cmd_exec() {
    local profile="$1"
    local cmd="$2"
    local timeout="${3:-30}"

    if [ -z "$profile" ] || [ -z "$cmd" ]; then
        echo "Usage: sshc exec <profile> <command> [timeout]" >&2
        return 1
    fi

    # python3 for JSON encoding (command may contain special chars)
    local req
    req=$(python3 -c "
import json, sys
print(json.dumps({'action':'exec','profile':sys.argv[1],'cmd':sys.argv[2],'timeout':int(sys.argv[3])}))
" "$profile" "$cmd" "$timeout")
    local resp
    resp=$(send "$req")

    python3 -c "
import sys, json
resp = json.load(sys.stdin)
if resp.get('ok'):
    out = resp.get('stdout','')
    err = resp.get('stderr','')
    if out: sys.stdout.write(out)
    if err: sys.stderr.write(err)
    sys.exit(0)
else:
    print('ERROR: ' + resp.get('error',''), file=sys.stderr)
    sys.exit(resp.get('exit', 1))
" <<< "$resp"
}

cmd_health() {
    local profile="${1:-}"
    local req
    if [ -n "$profile" ]; then
        req="{\"action\":\"health\",\"profile\":\"$profile\"}"
    else
        req='{"action":"health"}'
    fi

    local resp
    resp=$(send "$req")

    python3 -c "
import sys, json, os
resp = json.load(sys.stdin)
cfg = json.load(open(os.path.expanduser('$PROFILES_FILE')))
default = cfg.get('default','')
profile = sys.argv[1] if len(sys.argv) > 1 else ''

if profile:
    alive = resp.get('alive', False)
    mark = '●' if alive else '○'
    print(f'{mark} {profile}: {\"alive\" if alive else \"dead\"}')
else:
    for name, r in sorted(resp.items()):
        mark = '●' if r.get('alive') else '○'
        tag = ' (default)' if name == default else ''
        print(f'{mark} {name}{tag}: {\"alive\" if r.get(\"alive\") else \"dead\"}')
" "$profile" <<< "$resp"
}

cmd_profiles() {
    local resp
    resp=$(send '{"action":"profiles"}')
    echo "$resp" | python3 -c "
import json, sys, os
cfg = json.load(open(os.path.expanduser('$PROFILES_FILE')))
default = cfg.get('default','')
resp = json.load(sys.stdin)
print(f'{\"NAME\":<20} {\"HOST\":<22} {\"USER\":<10} {\"PORT\":<6} {\"STATUS\"}')
print('-' * 70)
for name in sorted(resp.keys()):
    r = resp[name]
    status = '● alive' if r['alive'] else '○ dead'
    tag = ' (default)' if r.get('default') else ''
    print(f'{name+tag:<20} {r[\"host\"]:<22} {r[\"user\"]:<10} {str(r[\"port\"]):<6} {status}')
" 2>/dev/null
}

cmd_add() {
    local name="" target="" key="" port="22" proxy="" allow="" deny=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -i) key="$2"; shift 2 ;;
            -p) port="$2"; shift 2 ;;
            --proxy) proxy="$2"; shift 2 ;;
            --allow) allow="$2"; shift 2 ;;
            --deny) deny="$2"; shift 2 ;;
            -*) echo "Unknown flag: $1" >&2; return 1 ;;
            *)
                if [ -z "$name" ]; then name="$1"
                elif [ -z "$target" ]; then target="$1"
                fi
                shift
                ;;
        esac
    done

    if [ -z "$name" ] || [ -z "$target" ]; then
        echo "Usage: sshc add <name> <user@host> -i <key> [-p <port>]" >&2
        return 1
    fi

    if [[ ! "$target" == *@* ]]; then
        echo "ERROR: target format is user@host" >&2
        return 1
    fi

    if [ -n "$key" ] && [ ! -f "$key" ]; then
        echo "ERROR: key file not found: $key" >&2
        return 1
    fi

    local user="${target%@*}"
    local host="${target#*@}"

    python3 -c "
import json, os, sys
f = os.path.expanduser('$PROFILES_FILE')
os.makedirs(os.path.expanduser('$APP_DIR'), exist_ok=True)
cfg = json.load(open(f)) if os.path.exists(f) else {}
cfg.setdefault('servers', {})[sys.argv[1]] = {
    'host': sys.argv[2], 'user': sys.argv[3], 'key': sys.argv[4], 'port': int(sys.argv[5]),
    'proxy': sys.argv[6], 'allow': sys.argv[7], 'deny': sys.argv[8]
}
if not cfg.get('default'):
    cfg['default'] = sys.argv[1]
json.dump(cfg, open(f+'.tmp', 'w'), indent=2)
os.replace(f+'.tmp', f)
os.chmod(f, 0o600)
print(f\"Added profile '{sys.argv[1]}': {sys.argv[3]}@{sys.argv[2]}\")
" "$name" "$host" "$user" "$key" "$port" "$proxy" "$allow" "$deny"
}

cmd_remove() {
    local name="$1"
    [ -z "$name" ] && { echo "Usage: sshc remove <name>" >&2; return 1; }
    python3 -c "
import json, os, sys
f = os.path.expanduser('$PROFILES_FILE')
cfg = json.load(open(f))
name = sys.argv[1]
if name in cfg.get('servers',{}):
    del cfg['servers'][name]
    if cfg.get('default') == name:
        cfg['default'] = next(iter(cfg['servers'])) if cfg['servers'] else ''
    json.dump(cfg, open(f+'.tmp', 'w'), indent=2)
    os.replace(f+'.tmp', f)
    print(f\"Removed profile '{name}'\")
else:
    print(f\"ERROR: profile '{name}' not found\")
" "$name" 2>/dev/null
}

cmd_default() {
    local name="$1"
    [ -z "$name" ] && { echo "Usage: sshc default <name>" >&2; return 1; }
    python3 -c "
import json, os, sys
f = os.path.expanduser('$PROFILES_FILE')
cfg = json.load(open(f))
name = sys.argv[1]
if name in cfg.get('servers',{}):
    cfg['default'] = name
    json.dump(cfg, open(f+'.tmp', 'w'), indent=2)
    os.replace(f+'.tmp', f)
    print(f\"Default profile: {name}\")
else:
    print(f\"ERROR: profile '{name}' not found\")
" "$name" 2>/dev/null
}

cmd_reconnect() {
    local profile="$1"
    [ -z "$profile" ] && { echo "Usage: sshc reconnect <profile>" >&2; return 1; }
    local resp
    resp=$(send "{\"action\":\"reconnect\",\"profile\":\"$profile\"}")
    echo "$resp" | python3 -c "import sys,json; d=json.load(sys.stdin); print(d.get('msg','') or d.get('error',''))" 2>/dev/null
}

cmd_upload() {
    local profile="$1" local_path="$2" remote_path="$3"

    if [ -z "$profile" ] || [ -z "$local_path" ] || [ -z "$remote_path" ]; then
        echo "Usage: sshc upload <profile> <local> <remote>" >&2; return 1
    fi
    if [ ! -e "$local_path" ]; then
        echo "ERROR: local path not found: $local_path" >&2; return 1
    fi

    python3 -c "
import json, os, sys, subprocess

f = os.path.expanduser('$PROFILES_FILE')
cfg = json.load(open(f))
s = cfg['servers'].get(sys.argv[1])
if not s: sys.exit('ERROR: profile not found')

sock = os.path.expanduser('$APP_DIR') + '/mux/ssh-' + sys.argv[1]
target = s['user'] + '@' + s['host']

opts = ['-o', 'ControlPath=' + sock, '-o', 'Port=' + str(s.get('port',22)),
        '-o', 'StrictHostKeyChecking=accept-new', '-o', 'ConnectTimeout=30']
if not s.get('password') and s.get('key'):
    opts += ['-i', os.path.expanduser(s['key'])]
if s.get('proxy'): opts += ['-o', 'ProxyCommand=' + s['proxy']]

local, remote = sys.argv[2], sys.argv[3]
prefix = ['sshpass', '-p', s['password']] if s.get('password') else []

if os.path.isdir(local):
    p1 = subprocess.Popen(['tar', 'czf', '-', '-C', os.path.dirname(local), os.path.basename(local)],
                          stdout=subprocess.PIPE)
    p2 = subprocess.Popen(prefix + ['ssh'] + opts + [target, 'mkdir -p ' + remote + '; tar xzf - -C ' + remote],
                          stdin=p1.stdout)
    p1.stdout.close()
    sys.exit(p2.wait())
else:
    subprocess.run(prefix + ['scp'] + opts + [local, target + ':' + remote])
" "$profile" "$local_path" "$remote_path"
}

cmd_download() {
    local profile="$1" remote_path="$2" local_path="$3"

    if [ -z "$profile" ] || [ -z "$remote_path" ] || [ -z "$local_path" ]; then
        echo "Usage: sshc download <profile> <remote> <local>" >&2; return 1
    fi

    python3 -c "
import json, os, sys, subprocess

f = os.path.expanduser('$PROFILES_FILE')
cfg = json.load(open(f))
s = cfg['servers'].get(sys.argv[1])
if not s: sys.exit('ERROR: profile not found')

sock = os.path.expanduser('$APP_DIR') + '/mux/ssh-' + sys.argv[1]
target = s['user'] + '@' + s['host']

opts = ['-o', 'ControlPath=' + sock, '-o', 'Port=' + str(s.get('port',22)),
        '-o', 'StrictHostKeyChecking=accept-new', '-o', 'ConnectTimeout=30']
if not s.get('password') and s.get('key'):
    opts += ['-i', os.path.expanduser(s['key'])]
if s.get('proxy'): opts += ['-o', 'ProxyCommand=' + s['proxy']]

remote, local = sys.argv[2], sys.argv[3]
prefix = ['sshpass', '-p', s['password']] if s.get('password') else []

os.makedirs(os.path.dirname(local) or '.', exist_ok=True)
# check if remote is a directory → tar pipe
check = subprocess.run(prefix + ['ssh'] + opts + [target, 'test -d ' + remote + ' && echo DIR || echo FILE'],
                       capture_output=True, text=True)
if 'DIR' in check.stdout:
    subprocess.run(prefix + ['ssh'] + opts + [target, 'tar czf - -C ' + remote + ' .'],
                   stdout=open(local, 'wb'))
else:
    subprocess.run(prefix + ['scp'] + opts + [target + ':' + remote, local])
" "$profile" "$remote_path" "$local_path"
    # sftp exits 0 on success; tar pipe may return non-zero on empty dirs
    return 0
}

cmd_web() {
    local port="${1:-17375}"
    echo "Starting sshc web UI on http://127.0.0.1:$port"
    python3 "$WEB_BIN" -p "$port"
}

# ── main ────────────────────────────────────────────────────────────
case "${1:-}" in
    daemon)   cmd_daemon ;;
    exec)     shift; cmd_exec "$@" ;;
    health)   shift; cmd_health "$@" ;;
    profiles) cmd_profiles ;;
    add)      shift; cmd_add "$@" ;;
    remove)   shift; cmd_remove "$@" ;;
    default)  shift; cmd_default "$@" ;;
    reconnect) shift; cmd_reconnect "$@" ;;
    upload)   shift; cmd_upload "$@" ;;
    download) shift; cmd_download "$@" ;;
    web)      shift; cmd_web "$@" ;;
    *)        echo "Usage: sshc {daemon|exec|health|profiles|add|remove|default|reconnect|web} ..." >&2; exit 1 ;;
esac
